<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <View
        android:id="@+id/splashGlow"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center"
        android:alpha="0"
        android:background="@drawable/splash_glow" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/splashIcon"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_splash_logo" />

        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:letterSpacing="0.06"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/splashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/splash_tagline"
            android:textColor="@color/text_muted"
            android:textSize="@dimen/text_small" />

        <View
            android:id="@+id/splashBar"
            android:layout_width="120dp"
            android:layout_height="3dp"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/splash_bar" />

        <LinearLayout
            android:id="@+id/splashDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:orientation="horizontal">

            <View
                android:id="@+id/splashDot1"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/splash_dot" />

            <View
                android:id="@+id/splashDot2"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginHorizontal="@dimen/spacing_xs"
                android:background="@drawable/splash_dot" />

            <View
                android:id="@+id/splashDot3"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/splash_dot" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
