<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/panel_border"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/panel_header_bg"
        android:letterSpacing="0.06"
        android:paddingHorizontal="@dimen/spacing_sm"
        android:paddingVertical="@dimen/panel_header_padding_v"
        android:text="@string/debug_area"
        android:textColor="@color/text_muted"
        android:textSize="@dimen/text_label"
        android:textStyle="bold" />

    <ScrollView
        android:id="@+id/debugScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/debug_bg"
        android:fillViewport="true"
        android:padding="@dimen/spacing_sm"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="1dp"
            android:text="@string/result_placeholder"
            android:textColor="@color/debug_info"
            android:textIsSelectable="true"
            android:textSize="@dimen/text_mono" />
    </ScrollView>
</LinearLayout>
