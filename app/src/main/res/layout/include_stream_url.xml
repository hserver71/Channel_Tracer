<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/panel_border"
    android:orientation="vertical"
    android:padding="@dimen/panel_padding">

    <EditText
        android:id="@+id/streamUrlInput"
        android:layout_width="match_parent"
        android:layout_height="@dimen/input_height"
        android:background="@drawable/input_field"
        android:hint="@string/stream_url_hint"
        android:inputType="textUri"
        android:paddingHorizontal="@dimen/spacing_sm"
        android:singleLine="true"
        android:textColor="@color/accent_teal"
        android:textColorHint="@color/text_muted"
        android:textSize="@dimen/text_small" />
</LinearLayout>
