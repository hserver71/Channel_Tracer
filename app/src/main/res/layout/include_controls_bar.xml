<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/panel_border"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/panel_padding">

    <EditText
        android:id="@+id/secondsInput"
        android:layout_width="32dp"
        android:layout_height="@dimen/input_height"
        android:background="@drawable/input_field"
        android:gravity="center"
        android:hint="@string/second_hint"
        android:inputType="number"
        android:singleLine="true"
        android:text="30"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textSize="@dimen/text_body" />

    <Spinner
        android:id="@+id/userAgentSpinner"
        android:layout_width="0dp"
        android:layout_height="@dimen/input_height"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_weight="1"
        android:background="@drawable/spinner_bg"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="16dp"
        android:spinnerMode="dropdown" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/startButton"
        style="@style/Widget.ChannelTracer.Button"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/button_height"
        android:layout_marginStart="@dimen/spacing_sm"
        android:background="@drawable/btn_primary"
        android:minWidth="84dp"
        android:text="@string/start_selected"
        android:textColor="@color/white"
        app:backgroundTint="@null" />
</LinearLayout>
